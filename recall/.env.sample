GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=

MICROSOFT_OUTLOOK_OAUTH_CLIENT_ID=
MICROSOFT_OUTLOOK_OAUTH_CLIENT_SECRET=

RECALL_API_HOST=https://api.recall.ai
RECALL_API_KEY=YOUR_RECALL_API_KEY

PUBLIC_URL=
PORT=3003
SECRET=
REQUEST_ONLY_CALENDAR_SCOPES=

# Redis (required for background jobs: publishing, sync, etc.)
# Against Railway from your laptop: use the Redis *public* URL (not redis.railway.internal).
# Pull with: ../run-local-with-railway-db.sh --pull  (writes REDIS_URL from REDIS_PUBLIC_URL when set).
# Or local-only: REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=

# AssemblyAI (optional – for Super Agent / premium analysis)
# Get your API key from https://www.assemblyai.com/app/account
# ASSEMBLYAI_API_URL is optional (default: https://api.assemblyai.com)
ASSEMBLYAI_API_KEY=
# ASSEMBLYAI_API_URL=https://api.assemblyai.com
# EU transcription: ASSEMBLYAI_API_URL=https://api.eu.assemblyai.com
# EU LLM Gateway (if your account uses EU): ASSEMBLYAI_LLM_GATEWAY_URL=https://llm-gateway.eu.assemblyai.com/v1
# ASSEMBLYAI_LLM_GATEWAY_URL=https://llm-gateway.assemblyai.com/v1
# ASSEMBLYAI_SUPER_AGENT_MODEL=claude-sonnet-4-5-20250929
# ASSEMBLYAI_SUPER_AGENT_MAX_TRANSCRIPT_CHARS=200000
# Optional: webhook secret for AssemblyAI callbacks (e.g. from AssemblyAI dashboard)
# ASSEMBLYAI_WEBHOOK_SECRET=
# ASSEMBLYAI_WEBHOOK_HEADER_NAME=x-assemblyai-webhook-secret